<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape>
            <!-- Chosen role: Light Gray background -->
            <solid android:color="@color/surface_container" />
            <stroke android:width="2.5dp" android:color="@color/outline" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item>
        <shape>
            <!-- Unchosen: White background -->
            <solid android:color="@color/white" />
            <stroke android:width="1dp" android:color="@color/outline_variant" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</selector>
